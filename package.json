{
  "name": "masaojss-helper",
  "displayName": "MasaoJSS Helper",
  "description": "MasaoJSS API Documentation for Visual Studio Code",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "publisher": "urotaichi",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/urotaichi/masaojss-helper"
  },
  "bugs": {
    "url": "https://github.com/urotaichi/masaojss-helper/issues"
  },
  "homepage": "https://github.com/urotaichi/masaojss-helper#readme",
  "qna": "https://github.com/urotaichi/masaojss-helper/discussions",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "publish:all": "npm run publish && npm run publish:ovsx"
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:html",
    "onLanguage:php"
  ],
  "contributes": {
    "jsDocCompletionLines": 2
  },
  "main": "./out/extension.js",
  "keywords": [
    "canvas-masao",
    "masao",
    "supermasao",
    "masaojs",
    "masaojs-helper"
  ],
  "author": "urotaichi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.74.0",
    "ovsx": "^0.10.12",
    "typescript": "^6.0.3",
    "vscode-test": "^1.6.1"
  }
}
